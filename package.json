  "description": "KP Front — Einsatzführungs-app for frontline fire-service command: situation map, plan whiteboard, live documentation, offline-capable.",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
