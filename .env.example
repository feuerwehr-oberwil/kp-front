# Self-host configuration for docker-compose (one fire station = one deployment).
# Copy to .env and fill in the two required secrets. Railway deploys ignore this file.
#
#   cp .env.example .env
#   docker compose up -d --build

# --- Required ---------------------------------------------------------------------
# Postgres password for the bundled db service (any strong value; used on first boot).
POSTGRES_PASSWORD=change-me-strong-password
# Signs JWTs AND peppers PINs — keep it STABLE (changing it logs everyone out / breaks PINs).
# Generate: openssl rand -hex 32
SECRET_KEY=
# Unlocks the /admin UI + admin-write API/CLI (config, branding, users, geodata/objects) —
# SEPARATE from the incident editor PIN. Generate: openssl rand -hex 24. Empty = admin
# surface DISABLED (fail-closed). Required to administer this deployment.
ADMIN_SECRET=

# --- Networking -------------------------------------------------------------------
# Host port the app listens on (plain HTTP). Put a reverse proxy / the tls profile in front.
APP_PORT=8000
# Force-disable Secure cookies for plain-HTTP access on a trusted LAN (no domain/TLS).
# Leave blank when serving over HTTPS. Values: true | false
COOKIE_SECURE=

# --- Automatic HTTPS (only used with: docker compose --profile tls up -d) ----------
# Domain whose A/AAAA record points at this host. Caddy gets a cert automatically.
DOMAIN=

# --- Database identity (optional; defaults shown) ----------------------------------
POSTGRES_USER=kpfront
POSTGRES_DB=kpfront

# --- Seeding ----------------------------------------------------------------------
# First boot seeds the default editor from backend/app/seed_users.json — user "fu"
# (Führungsunterstützung), role editor, PIN 000000. Idempotent; change the PIN after first login.
SEED_DATABASE=true

# --- Optional integrations (leave blank to disable) --------------------------------
# Divera 24/7 (alarms / roster)
DIVERA_ACCESS_KEY=
# Optional: a second accesskey whose Divera user can read members' Qualifikationen — enables
# deriving each crew member's Dienstgrad (rank) during roster sync. Empty = names only.
DIVERA_PERSONNEL_ACCESS_KEY=
# Required to receive push alarms via /api/divera/webhook — the webhook rejects everything
# (403) while this is empty, so nobody can inject fake alarms. Polling works without it.
DIVERA_WEBHOOK_SECRET=

# Generic alarm intake for non-Divera alerting systems: POST /api/alarms auto-opens an
# incident per alarm (idempotent on source+source_id). Empty = endpoint disabled (403).
ALARM_WEBHOOK_SECRET=
# Public origin (https://front.example.org) for absolute links in outbound incident
# webhooks (docs/ALARM-INTEGRATIONS.md). Empty = links omitted.
PUBLIC_URL=

# Web Push (killed-app Atemschutz/Wiedervorlage alarms + new-alarm push). Generate a VAPID pair once:
#   cd backend && uv run python -m app.gen_vapid    (or: npx web-push generate-vapid-keys)
# and paste both keys (URL-safe base64). Empty = push disabled; in-app alarms still work.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for push-service operators (mailto: or https:)
VAPID_SUBJECT=mailto:admin@example.org
# Traccar (live vehicle GPS)
TRACCAR_URL=
TRACCAR_EMAIL=
TRACCAR_PASSWORD=

# Station print relay: «An Stationsdrucker» queues the Einsatzrapport-PDF for an on-site
# polling agent (tools/print_agent.py). Empty = agent endpoints 403 (fail-closed).
PRINT_AGENT_SECRET=

# Speech-to-text for the audio player's Transkribieren (OpenAI-compatible
# /v1/audio/transcriptions server, base URL WITHOUT /v1):
#   Groq (free tier):  STT_BASE_URL=https://api.groq.com/openai   STT_MODEL=whisper-large-v3-turbo
#   OpenAI:            STT_BASE_URL=https://api.openai.com        STT_MODEL=whisper-1
#   self-hosted (speaches/faster-whisper-server): STT_BASE_URL=http://host:8000, key optional
# Empty base URL = STT off everywhere (fail-closed). Audio leaves the instance only when set.
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=whisper-large-v3-turbo
STT_LANGUAGE=de

# --- Tuning (optional; defaults shown) ---------------------------------------------
# Request-body cap for multipart uploads in MB — must stay above the media endpoint's
# 100 MB per-file cap.
MAX_UPLOAD_MB=110
# swisstopo SearchServer for address autocomplete. Not a generic-geocoder swap point —
# override only with an endpoint speaking the same SearchServer API.
GEOCODER_URL=https://api3.geo.admin.ch/rest/services/api/SearchServer
