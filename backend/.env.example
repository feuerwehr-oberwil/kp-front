# --- Core ---
# Local dev Postgres (spin up with: docker run ... postgres:16 ; or reuse a container).
DATABASE_URL=postgresql+asyncpg://kpfront:kpfront@localhost:5434/kpfront
# Pepper for PINs AND JWT signing. Generate: openssl rand -hex 32
# (Auto-generated in dev if empty; REQUIRED in production.)
SECRET_KEY=

# --- Deployment-admin auth ---
# Shared secret that unlocks the /admin UI and the admin-write API/CLI (config, branding,
# system, user CRUD, geodata/objects) — SEPARATE from the incident editor PIN. Generate:
# openssl rand -hex 24. Empty = admin surface DISABLED (fail-closed): admin endpoints 403
# until set. Never falls back to the editor PIN. The admin_geodata/admin_objects `push`
# CLI authenticates with this (KP_ADMIN_SECRET).
ADMIN_SECRET=

# --- Seeding ---
# When true, on startup seed users from SEED_USERS_FILE if the users table is empty.
SEED_DATABASE=true
SEED_USERS_FILE=app/seed_users.json

# --- Single-service SPA serving (production) ---
# Path to the built Vite SPA (dist/). When set and present, FastAPI serves it.
SPA_DIR=../dist

# --- Object storage (media, reference data, snapshot blobs) ---
MEDIA_STORAGE_DIR=data/storage

# --- Divera 24/7 (Phase 3; empty access key disables polling) ---
DIVERA_ACCESS_KEY=
# Optional: a second accesskey whose Divera user can read members' Qualifikationen — enables
# deriving each crew member's Dienstgrad (rank) during roster sync. Leave empty to sync names
# only (the alarm key above usually can't see qualifications).
DIVERA_PERSONNEL_ACCESS_KEY=
DIVERA_API_URL=https://app.divera247.com/api/v2
DIVERA_POLL_INTERVAL_SECONDS=120
DIVERA_POLL_MAX_ALARMS=50
# Required to receive push alarms via /api/divera/webhook — the webhook rejects everything
# (403) while this is empty (fail-closed). Polling works without it.
DIVERA_WEBHOOK_SECRET=

# --- Generic alarm intake (non-Divera alerting systems) ---
# POST /api/alarms auto-opens an incident per alarm, idempotent on (source, source_id).
# Fail-closed: empty = endpoint disabled (403). Setting a secret is the opt-in.
ALARM_WEBHOOK_SECRET=
# Public origin of this deployment (https://front.example.org) — composes absolute links in
# outbound incident webhooks (capture URL on the alarm slip). Empty = links omitted.
PUBLIC_URL=

# --- Web Push (killed-app Atemschutz/Wiedervorlage alarms + new-alarm push) ---
# Generate once: uv run python -m app.gen_vapid  (URL-safe base64 pair).
# Empty = push disabled; the in-app alarm path keeps working.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.org

# --- Traccar (Phase 6) ---
TRACCAR_URL=
TRACCAR_EMAIL=
TRACCAR_PASSWORD=
# Dev/testing only: serve injected fake positions instead of a real Traccar server
# (uv run python -m app.fake_scenario). Never set in a field deployment.
TRACCAR_FAKE=

# --- Speech-to-text (player Transkribieren) ---
# OpenAI-compatible /v1/audio/transcriptions server, base URL WITHOUT /v1:
#   Groq (free tier):  STT_BASE_URL=https://api.groq.com/openai   STT_MODEL=whisper-large-v3-turbo
#   OpenAI:            STT_BASE_URL=https://api.openai.com        STT_MODEL=whisper-1
#   self-hosted (speaches/faster-whisper-server): STT_BASE_URL=http://host:8000, key optional
# Empty base URL = STT off everywhere (fail-closed). Audio leaves the instance only when set.
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=whisper-large-v3-turbo
STT_LANGUAGE=de

# --- swisstopo geocoder (Phase 3/4) ---
GEOCODER_URL=https://api3.geo.admin.ch/rest/services/api/SearchServer
